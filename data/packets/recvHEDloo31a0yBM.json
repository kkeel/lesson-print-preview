    {
      "type": "howto",
      "pages": [
        {
          "title": "Plutarch/Government: Grade 9 (U.S.)",
          "subtitle": "How To Approach",
          "editUrl": "https://airtable.com/apphTWdjAdJEcAmoe/pag2S8wmDF4fbWaAv/recoGVeIpXhg80gcr?XRKkD=recVqTvJ6GPeafHaJ&6J82c=rec29oxFWTUnXF541&home=pago27hsdn3q8TtGK",
          "blocks": [
            {
              "prompt": "Prepare",
              "text": "Teachers may find it helpful to pre-read all or part of the selection from Plutarch studied and choose which news sites to offer students.\n\nIf you, the student, are learning at home, work to schedule a time with your teacher when you can complete the lessons from Ourselves and Plutarch together, as these lessons are much richer when shared and discussed.",
              "imageId": "rec6mwte9GhEBIan2",
              "image": "../images/howto_images/rec6mwte9GhEBIan2.webp"
            },
            {
              "prompt": "Recap",
              "text": "Connect back to the previous lesson. (Optional for Current Events).",
              "imageId": "recLDUhM0HxOUkXQh",
              "image": "../images/howto_images/recLDUhM0HxOUkXQh.webp"
            },
            {
              "prompt": "Introduce",
              "text": "For news sources: Scan the headlines first to get an overview, and then choose a story to read. \n\nFor Citizenship books (optional): Use a picture, a map, or an engaging question to get yourselves interested in the lesson. If necessary, you may talk about one or two unfamiliar words that will be crucial to understanding. It is not necessary to cover all unfamiliar words.",
              "imageId": "recA2NEUDRjP5aLqn",
              "image": "../images/howto_images/recA2NEUDRjP5aLqn.webp"
            },
            {
              "prompt": "Read",
              "text": "Read the selection assigned or the news story chosen. For rich, dense, or more challenging books such as Ourselves and Plutarch, it is a good idea to read them aloud. Have students keep an eye out for things to add to their Citizenship Notebook, Book of Centuries, and/or Commonplace book.",
              "imageId": "rec8qCc9QiAta9SiI",
              "image": "../images/howto_images/rec8qCc9QiAta9SiI.webp"
            },
            {
              "prompt": "Narrate",
              "text": "Narrate orally or in writing.",
              "imageId": "recIUhyVu1Y1l6aP9",
              "image": "../images/howto_images/recIUhyVu1Y1l6aP9.webp"
            },
            {
              "prompt": "Discuss",
              "text": "Share your thoughts on the story and any connections made. For current events, look up where events occurred on a map and ask questions together to discern the quality of the piece. (e.g., Are there sources cited? Is there an obvious bias? If so, what do other authors have to say on this subject? Are arguments supported by evidence? Is that evidence credible?) Consider reading an alternative perspective.",
              "imageId": "recNNZHVLXJY6vLgN",
              "image": "../images/howto_images/recNNZHVLXJY6vLgN.webp"
            },
            {
              "prompt": "Citizenship Notebook",
              "text": "Record important ideas in your Citizenship Notebooks. Make a calendar of current events.",
              "imageId": "recxHTB15V7kHGc7A",
              "image": "../images/howto_images/recxHTB15V7kHGc7A.webp"
            }
          ]
        }
      ]
    },
