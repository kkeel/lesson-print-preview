        {
          "kind": "about-group",
          "title": "About the Course",
          "entries": [
            {
              "title": "About the Course",
              "content": "In addition to reading a variety of poems from 19th century authors, students read biographies of two famous 19th century poets and dive into Virgil's Aeneid. \n\nThis topic is included in the following course(s): Literature: Grade 11, Literature: Grade 12, Literature: Grade 9, Literature: Grade 10"
            }
          ]
        },
        {
          "kind": "tips-group",
          "title": "Placement & Combining Tips",
          "entries": [
            {
              "title": "Placement & Combining Tips",
              "content": "Students new or struggling in their relationship with poetry should use Grade 8 lessons."
            }
          ]
        },
