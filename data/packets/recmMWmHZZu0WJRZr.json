            },
            {
              "prompt": "Introduce",
              "text": "Teach students the new song, dance, or sport. Tutorials are often provided.",
              "imageId": "recA2NEUDRjP5aLqn",
              "image": "../images/howto_images/recA2NEUDRjP5aLqn.webp"
            },
            {
              "prompt": "Practice",
